# ─────────────────────────────────────────────────────────────
# PORTUGOOOL — environment variables
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored. NEVER commit real keys.
# ─────────────────────────────────────────────────────────────

# Public site URL (used for Stripe redirect URLs). No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase ──────────────────────────────────────────────────
# Project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-only. Bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe ────────────────────────────────────────────────────
# Dashboard → Developers → API keys. Use test keys (sk_test_/pk_test_) first.
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Optional custom line item for the name/number add-on (falls back to inline price).
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Resend (emails — wired up later) ──────────────────────────
RESEND_API_KEY=re_xxx

# ── Printful / Printify (fulfilment — wired up later) ─────────
PRINTFUL_API_KEY=
PRINTIFY_API_KEY=
